# Server
PORT=8080
BASE_URL=https://blueprintautomation.tech

# Database (optional — server runs without it, logs a warning)
DATABASE_URL=postgres://bpa:password@localhost:5432/bpa_website?sslmode=disable

# Phase 1 — Lead Engine
CAL_COM_URL=https://cal.com/YOUR_USERNAME/discovery           # Your Cal.com booking link
RESEND_API_KEY=re_xxxxxxxxxxxx                                # Resend.com email API key
NOTIFY_EMAIL=anthony@blueprintautomation.tech                 # Where lead alerts go
FROM_EMAIL=hello@blueprintautomation.tech                     # Outbound email from address
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy  # Lead notification channel

# ROI Tool embed (Phase 1 — leave blank until deployed)
ROI_TOOL_URL=                   # Leave blank until roiautomationcalc is deployed
ROI_TENANT_ID=                  # BPA's tenant ID in roiautomationcalc

# Phase 2 — Post-Sale Payment
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
BPA_INTERNAL_KEY=               # Shared secret for internal API calls from Blueprint Command
BLUEPRINT_COMMAND_API_URL=http://localhost:8094               # Blueprint Command provisioner
BLUEPRINT_COMMAND_ADMIN_KEY=bpa_super_xxxx

# Phase 3 — Self-Serve Checkout
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_WEBCHAT_SETUP=price_xxxx                         # $297 one-time setup
STRIPE_PRICE_WEBCHAT_MONTHLY=price_xxxx                       # $197/month subscription
STRIPE_PRICE_REVIEWS_SETUP=price_xxxx                         # $197 one-time setup
STRIPE_PRICE_REVIEWS_MONTHLY=price_xxxx                       # $99/month subscription

# Phase 4 — Partner Application
PARTNER_NOTIFY_EMAIL=anthony@blueprintautomation.tech
